rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "asad01qw@gmail.com" && request.auth.token.email_verified == true));
    }

    // User profiles
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && request.resource.data.role == 'client';
      allow update: if isOwner(uid) && request.resource.data.role == resource.data.role;
      allow write: if isAdmin();
    }

    // Portfolio projects
    match /projects/{projectId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Client projects tracking
    match /clientProjects/{projectId} {
      allow read: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // Chat messages
    match /chats/{chatId}/messages/{messageId} {
      allow read: if isAuthenticated() && (chatId.contains(request.auth.uid) || isAdmin());
      allow create: if isAuthenticated() && (chatId.contains(request.auth.uid) || isAdmin());
    }

    // Testimonials
    match /testimonials/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
